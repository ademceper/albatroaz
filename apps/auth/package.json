{
  "name": "auth",
  "version": "0.0.0",
  "description": "Keycloakify auth theme",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "keycloakify sync-extensions",
    "dev": "keycloakify start-keycloak --keycloak-version 26",
    "build": "tsc && vite build",
    "build-keycloak-theme": "pnpm build && keycloakify build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "@albatroaz/ui": "workspace:*",
    "@keycloak/keycloak-admin-client": "26.5.2",
    "@phosphor-icons/react": "^2.1.10",
    "i18next": "^25.7.3",
    "i18next-fetch-backend": "^6.0.0",
    "keycloakify": "^11.15.0",
    "lodash-es": "^4.17.22",
    "oidc-spa": "~10.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.70.0",
    "react-i18next": "^16.5.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.30.2",
    "sonner": "^2.0.7",
    "@keycloakify/keycloak-admin-ui": "~260502.0.0",
    "@dagrejs/dagre": "^1.1.8",
    "@keycloakify/keycloak-ui-shared": "~260502.0.0",
    "@patternfly/patternfly": "^5.4.2",
    "@patternfly/react-core": "^5.4.14",
    "@patternfly/react-icons": "^5.4.2",
    "@patternfly/react-styles": "^5.4.1",
    "@patternfly/react-table": "^5.4.16",
    "@uiw/react-textarea-code-editor": "^3.1.1",
    "file-saver": "^2.0.5",
    "flat": "^6.0.1",
    "jszip": "^3.10.1",
    "p-debounce": "^5.1.0",
    "reactflow": "^11.11.4",
    "use-react-router-breadcrumbs": "^4.0.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@albatroaz/ts-cfg": "workspace:*",
    "@storybook/react": "^8.1.10",
    "@storybook/react-vite": "^8.1.10",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "storybook": "^8.1.10",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^5.0.8",
    "@types/file-saver": "^2.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
